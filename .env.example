# Server
VOICE_AGENT_HOST=127.0.0.1
VOICE_AGENT_PORT=8787
VOICE_AGENT_WEB_DIR=web

# Local-first provider routing
VOICE_AGENT_VAD_PROVIDER=silero
VOICE_AGENT_ASR_PROVIDER=foundry-local
VOICE_AGENT_TTS_PROVIDER=windows-sapi
VOICE_AGENT_LLM_PROVIDER=foundry-local
VOICE_AGENT_CLOUD_FALLBACK_ENABLED=false

# Foundry Local. Confirm model IDs with your Foundry Local catalog before first run.
# Leave empty to auto-discover `foundry service status`; set explicitly if needed.
VOICE_AGENT_FOUNDRY_ENDPOINT=
VOICE_AGENT_FOUNDRY_LLM_MODEL=qwen2.5-0.5b-instruct-cuda-gpu:4
VOICE_AGENT_FOUNDRY_ASR_MODEL=nemotron-3.5-asr-streaming-0.6b
VOICE_AGENT_FOUNDRY_TIMEOUT_SECONDS=180

# llama.cpp local LLM. Start the server with scripts\start_llama_cpp_e2b.ps1.
VOICE_AGENT_LLAMA_CPP_ENDPOINT=http://127.0.0.1:8080
VOICE_AGENT_LLAMA_CPP_MODEL=gemma-3n-e2b-it
VOICE_AGENT_LLAMA_CPP_MODEL_PATH=models/llm/gemma-3n-e2b-it/gemma-3n-E2B-it-Q4_K_M.gguf
VOICE_AGENT_LLAMA_CPP_SLOT_ID=0

# Local ASR fallback
VOICE_AGENT_ASR_LANGUAGE=auto
VOICE_AGENT_FASTER_WHISPER_MODEL=tiny
PASCO_MODEL_KEY=
VOICE_AGENT_AZURE_EMBEDDED_GRPC_URL=127.0.0.1:8792
VOICE_AGENT_AZURE_EMBEDDED_ASR_LOCALE=en-GB
VOICE_AGENT_AZURE_EMBEDDED_ASR_SIDECAR_URL=ws://127.0.0.1:8791/asr
VOICE_AGENT_AZURE_EMBEDDED_ASR_ZH_CN_MODEL_DIR=models/azure-embedded/asr/zh-CN/decrypted/35M
VOICE_AGENT_AZURE_EMBEDDED_ASR_EN_GB_MODEL_DIR=models/azure-embedded/asr/en-GB/decrypted/v6/35M
VOICE_AGENT_AZURE_EMBEDDED_TTS_VOICE=azure-embedded-zh-CN-XiaoxiaoNeuralV6
VOICE_AGENT_AZURE_EMBEDDED_TTS_ZH_CN_MODEL_DIR=models/azure-embedded/tts/zh-CN/XiaoxiaoNeuralV6
VOICE_AGENT_AZURE_EMBEDDED_TTS_EN_US_MODEL_DIR=models/azure-embedded/tts/en-US/AvaNeuralHDv2
VOICE_AGENT_WHISPER_CPP_MODEL_PATH=models/whisper/base-q5_1.gguf
VOICE_AGENT_VOSK_MODEL_PATH=models/vosk

# Windows TTS
VOICE_AGENT_WINDOWS_TTS_VOICE=
VOICE_AGENT_EDGE_TTS_VOICE=zh-CN-XiaoxiaoNeural
VOICE_AGENT_TTS_SAMPLE_RATE=24000

# Guarded Copilot/VS Code automation
VOICE_AGENT_COPILOT_TOOLS_ENABLED=true
VOICE_AGENT_COPILOT_TOOLS_DRY_RUN=true
VOICE_AGENT_COPILOT_TOOL_POLICY=.voice-agent/copilot-tools.json
VOICE_AGENT_COPILOT_AUDIT_LOG=.voice-agent/audit.jsonl
